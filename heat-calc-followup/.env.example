# ---- دیتابیس ----
DB_HOST=localhost
DB_NAME=shofazh
DB_USER=shofazh_user
DB_PASS=change-me

# ---- پنل پیامکی (کاوه‌نگار) ----
# آدرس پایه API کاوه‌نگار — معمولاً نیازی به تغییر ندارد
SMS_API_URL=https://api.kavenegar.com/v1
# کلید API از پنل کاوه‌نگار: حساب کاربری ← تنظیمات ← کلید API
SMS_API_KEY=change-me
# شماره خط ارسال (از بخش «خطوط من» در پنل کاوه‌نگار)
SMS_SENDER=10004346

# ---- تنظیمات پیگیری ----
# فاصله ارسال پیامک دوم بعد از محاسبه (ساعت)
FOLLOWUP_DELAY_HOURS=24
# حداکثر تعداد پیامک به هر شماره در بازه‌ی SMS_CAP_WINDOW_DAYS روز
MAX_SMS_PER_NUMBER=3
SMS_CAP_WINDOW_DAYS=30
# حداقل فاصله بین دو پیامک به یک شماره (ساعت)
MIN_SMS_INTERVAL_HOURS=20
# حداکثر تعداد ارسال در هر اجرای کرون
CRON_BATCH_SIZE=100

# ---- rate limit فرم ثبت شماره ----
# حداکثر ثبت از هر IP در یک ساعت
RATE_LIMIT_PER_IP_HOUR=5
# حداکثر ثبت برای هر شماره در ۲۴ ساعت
RATE_LIMIT_PER_PHONE_DAY=2

# ---- امنیت ----
# کلید محرمانه‌ی endpoint ثبت تبدیل (convert.php) — یک رشته تصادفی طولانی بگذارید
CONVERT_API_SECRET=change-me-random-long-string

# ---- لینک‌ها ----
# آدرس پایه سایت برای ساخت لینک لغو پیامک
SITE_BASE_URL=https://shofazh.com
# مسیر فایل لاگ (خارج از webroot)
LOG_FILE=/var/log/shofazh/sms.log
