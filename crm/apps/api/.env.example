# ── دیتابیس ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://crm:crm@localhost:5432/shofazh_crm?schema=public"

# ── احراز هویت (فاز ۳) ─────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL="900"        # ثانیه (۱۵ دقیقه)
JWT_REFRESH_TTL="2592000"   # ثانیه (۳۰ روز)

# ── Redis (کش/صف/pubsub — فاز ۳ به بعد) ────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Issabel / AMI (فاز ۴ — فعلاً شبیه‌ساز) ──────────────────────────────────────
AMI_HOST="127.0.0.1"
AMI_PORT="5038"
AMI_USERNAME="crm"
AMI_SECRET="change-me"
AMI_MOCK="true"             # تا راه‌اندازی Issabel واقعی

# ── لایه AI خودمیزبان (فاز ۶) ───────────────────────────────────────────────────
AI_BASE_URL="http://ai-inference:8000/v1"   # سرور سازگار با OpenAI (vLLM/Ollama)
AI_MODEL="qwen2.5-14b-instruct"
STT_BASE_URL="http://stt-whisper:9000"      # سرویس Whisper خودمیزبان
STT_MOCK="true"

# ─────────────────────────────────────────────────────────────────────────────
# نکته‌ی محیط سندباکس (proxy): اگر دانلود انجن Prisma با ECONNRESET شکست خورد،
# انجن‌ها با curl از طریق پروکسی pre-fetch شده و با این دو متغیر استفاده می‌شوند:
#   PRISMA_SCHEMA_ENGINE_BINARY=.prisma-engines/schema-engine
#   PRISMA_QUERY_ENGINE_LIBRARY=.prisma-engines/libquery_engine.so.node
# در محیط عادی توسعه/پروداکشن لازم نیست؛ npm install خودش انجن را می‌گیرد.
