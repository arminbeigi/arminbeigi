// ─────────────────────────────────────────────────────────────────────────────
// شفازح CRM — Prisma Schema (PHASE 2)
// PostgreSQL 16 · enterprise HVAC CRM + call center
// همه‌ی متن‌های دامنه فارسی‌اند؛ نام/کد محصول می‌تواند لاتین باشد (فارسی + لاتین).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm, unaccent, pgcrypto]
}

// ═══════════════════════════════════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════════════════════════════════

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum CustomerType {
  RESIDENTIAL // خانگی
  CONTRACTOR // پیمانکار
  COMPANY // شرکت
  BUILDING_PROJECT // پروژه ساختمانی
}

enum CustomerStatus {
  LEAD // سرنخ
  ACTIVE // فعال
  INACTIVE // غیرفعال
  BLOCKED // مسدود
}

enum LeadSource {
  PHONE_INBOUND // تماس ورودی
  PHONE_OUTBOUND // تماس خروجی
  WEBSITE // وب‌سایت
  REFERRAL // معرفی
  CAMPAIGN // کمپین
  WALK_IN // مراجعه حضوری
  OTHER // سایر
}

enum ProductCategory {
  BOILER // دیگ / پکیج
  BURNER // مشعل
  PUMP // پمپ
  TANK // منبع / مخزن
  RADIATOR // رادیاتور
  ACCESSORY // متعلقات
}

enum BoilerKind {
  WALL_PACKAGE // پکیج دیواری
  CAST_IRON // دیگ چدنی
  STEEL // دیگ فولادی
  GROUND // زمینی
  NONE // برای محصولاتی که دیگ نیستند
}

enum FuelType {
  GAS // گازی
  GASOIL // گازوئیلی
  DUAL // دوگانه‌سوز
  ELECTRIC // برقی
  NONE
}

enum ProjectType {
  ENGINE_ROOM // موتورخانه
  WALL_PACKAGE // پکیج دیواری
  CAST_IRON_BOILER // دیگ چدنی
  STEEL_BOILER // دیگ فولادی
  INSTALLATION // نصب
  SERVICE // سرویس
}

enum ProjectStatus {
  DRAFT // پیش‌نویس
  SURVEY // بازدید فنی
  PROPOSAL // پیشنهاد قیمت
  IN_PROGRESS // در حال اجرا
  ON_HOLD // متوقف
  COMPLETED // تکمیل‌شده
  CANCELLED // لغوشده
}

enum DealStatus {
  OPEN // باز
  WON // برنده
  LOST // ازدست‌رفته
}

enum CallDirection {
  INBOUND // ورودی
  OUTBOUND // خروجی
  INTERNAL // داخلی
}

enum CallStatus {
  RINGING // در حال زنگ
  ANSWERED // پاسخ‌داده‌شده
  NO_ANSWER // بی‌پاسخ
  BUSY // مشغول
  FAILED // ناموفق
  VOICEMAIL // پیغام‌گیر
}

enum TicketStatus {
  OPEN // باز
  IN_PROGRESS // در حال بررسی
  WAITING // در انتظار مشتری
  RESOLVED // حل‌شده
  CLOSED // بسته‌شده
}

enum TicketPriority {
  LOW // کم
  MEDIUM // متوسط
  HIGH // زیاد
  URGENT // فوری
}

enum TicketCategory {
  BREAKDOWN // خرابی
  INSTALLATION // نصب
  MAINTENANCE // سرویس دوره‌ای
  WARRANTY // گارانتی
  COMPLAINT // شکایت
  INQUIRY // استعلام
}

enum IntentType {
  PURCHASE // خرید
  BREAKDOWN // خرابی
  INSTALLATION // نصب
  SERVICE // سرویس
  UNKNOWN // نامشخص
}

enum InsightType {
  CALL_SUMMARY // خلاصه تماس
  CALL_INTENT // تشخیص نیت
  LEAD_SCORE // امتیاز سرنخ
  PRODUCT_RECOMMENDATION // پیشنهاد محصول
  NEXT_ACTION // اقدام بعدی
  TICKET_CLASSIFICATION // دسته‌بندی خودکار تیکت (دسته/اولویت/قطعه)
}

enum EntityType {
  CUSTOMER
  PROJECT
  DEAL
  CALL
  TICKET
  PRODUCT
  AUTH // رویدادهای احراز هویت (ورود/خروج/قفل) — ممیزی امنیتی (H1)
  USER
  ROLE
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTH / RBAC
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  fullName     String // نام کامل (فارسی)
  status       UserStatus @default(ACTIVE)
  extension    String? // داخلی تلفن (Issabel) برای مسیریابی پاپ‌آپ تماس
  avatarUrl    String?
  lastLoginAt  DateTime?
  // محافظت brute-force: شمارش تلاش‌های ناموفق و قفل موقت حساب (سخت‌سازی C1)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  roles            UserRole[]
  refreshTokens    RefreshToken[]
  ownedCustomers   Customer[]      @relation("CustomerOwner")
  assignedProjects Project[]       @relation("ProjectManager")
  ownedDeals       Deal[]          @relation("DealOwner")
  handledCalls     Call[]          @relation("CallAgent")
  assignedTickets  Ticket[]        @relation("TicketAssignee")
  ticketComments   TicketComment[]
  notes            Note[]
  activities       ActivityLog[]
  notifications    Notification[]

  @@index([status])
  @@index([extension])
}

model Role {
  id          String  @id @default(cuid())
  key         String  @unique // admin, sales_manager, sales_agent, call_center, technician, viewer
  name        String // نام نمایشی فارسی
  description String?
  isSystem    Boolean @default(false) // نقش‌های پایه که حذف نمی‌شوند

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id    String @id @default(cuid())
  key   String @unique // customers:read, deals:write, calls:manage ...
  group String // دسته‌بندی برای UI (مثلاً "مشتریان")
  name  String // توضیح فارسی

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // هش توکن (خود توکن ذخیره نمی‌شود)
  family    String // شناسه خانواده برای rotation/ابطال زنجیره‌ای
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// CUSTOMERS  (B2B + residential + contractors)
// ═══════════════════════════════════════════════════════════════════════════

model Customer {
  id           String         @id @default(cuid())
  code         String         @unique @default(cuid()) // کد مشتری قابل‌نمایش
  type         CustomerType
  status       CustomerStatus @default(LEAD)
  displayName  String // نام نمایشی (شخص یا شرکت)
  firstName    String? // برای خانگی
  lastName     String?
  companyName  String? // برای B2B
  nationalId   String? // کد ملی
  economicCode String? // کد اقتصادی (B2B)
  source       LeadSource     @default(OTHER)
  leadScore    Int            @default(0) // 0..100 — توسط لایه AI به‌روزرسانی می‌شود
  notesText    String? // یادداشت آزاد
  externalRef  String? // برای سینک آینده با ووکامرس (idempotent)

  ownerId String? // کارشناس مسئول
  owner   User?   @relation("CustomerOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  phones    CustomerPhone[]
  contacts  CustomerContact[]
  addresses Address[]
  projects  Project[]
  deals     Deal[]
  calls     Call[]
  tickets   Ticket[]
  notes     Note[]
  insights  AIInsight[]
  tags      CustomerTag[]

  @@unique([type, externalRef])
  @@index([type])
  @@index([status])
  @@index([ownerId])
  @@index([leadScore])
  @@index([displayName])
}

// شماره‌تلفن‌ها جدا هستند تا جست‌وجوی تماس ورودی روی همه‌ی شماره‌ها سریع باشد.
model CustomerPhone {
  id         String   @id @default(cuid())
  customerId String
  number     String // به فرمت نرمال‌شده ذخیره می‌شود (E.164/داخلی)
  rawNumber  String? // فرمت اصلی واردشده
  label      String? // موبایل / دفتر / کارگاه
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, number])
  @@index([number]) // حیاتی: تطبیق caller-id تماس ورودی
}

model CustomerContact {
  id         String  @id @default(cuid())
  customerId String
  fullName   String
  position   String? // سمت (مدیر فنی، خریدار...)
  phone      String?
  email      String?
  isPrimary  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([phone])
}

model Address {
  id         String  @id @default(cuid())
  customerId String
  title      String? // عنوان (دفتر مرکزی، کارگاه...)
  province   String? // استان
  city       String? // شهر
  line       String // آدرس کامل
  postalCode String?
  lat        Float?
  lng        Float?
  isPrimary  Boolean @default(false)

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([customerId])
  @@index([city])
}

// ═══════════════════════════════════════════════════════════════════════════
// PRODUCTS  (boilers, burners, pumps, tanks, radiators)
// ═══════════════════════════════════════════════════════════════════════════

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique // ممکن است لاتین باشد
  nameFa   String? // نام فارسی برند
  country  String?
  products Product[]
}

model Product {
  id          String          @id @default(cuid())
  sku         String          @unique // کد محصول (لاتین)
  name        String // نام محصول (فارسی + لاتین مجاز)
  category    ProductCategory
  boilerKind  BoilerKind      @default(NONE)
  fuelType    FuelType        @default(NONE)
  brandId     String?
  description String?
  externalRef String? // سینک آینده ووکامرس
  isActive    Boolean         @default(true)

  // مشخصات فنی HVAC (هر فیلد برای دسته‌ی مرتبط معنا دارد)
  capacityKcal Int? // ظرفیت حرارتی (kcal/h) — دیگ/مشعل
  capacityKw   Float? // ظرفیت (kW)
  efficiency   Float? // راندمان درصد
  pressureBar  Float? // فشار کاری — پمپ/منبع
  flowRate     Float? // دبی (m³/h) — پمپ
  headMeter    Float? // ارتفاع آبدهی (m) — پمپ
  capacityLit  Int? // حجم (لیتر) — منبع/مخزن
  material     String? // چدن / فولاد / استیل
  sections     Int? // تعداد پره — رادیاتور/دیگ چدنی
  specs        Json? // مشخصات تکمیلی انعطاف‌پذیر

  // قیمت و موجودی
  priceIrr   Decimal? @db.Decimal(18, 0) // قیمت به ریال
  stockQty   Int      @default(0)
  warrantyMo Int? // گارانتی (ماه)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  brand        Brand?        @relation(fields: [brandId], references: [id], onDelete: SetNull)
  dealItems    DealItem[]
  projectItems ProjectItem[]
  recommended  AIInsight[]   @relation("RecommendedProduct")

  @@index([category])
  @@index([boilerKind])
  @@index([fuelType])
  @@index([brandId])
  @@index([isActive])
  @@index([name])
}

// ═══════════════════════════════════════════════════════════════════════════
// PROJECTS  (engine room, installation, service)
// ═══════════════════════════════════════════════════════════════════════════

model Project {
  id          String        @id @default(cuid())
  code        String        @unique @default(cuid())
  title       String
  type        ProjectType
  status      ProjectStatus @default(DRAFT)
  customerId  String
  addressId   String? // محل اجرا
  managerId   String? // مدیر/سرپرست پروژه
  description String?

  // اطلاعات فنی موتورخانه/نصب
  buildingArea Float? // متراژ ساختمان
  floors       Int? // تعداد طبقات
  units        Int? // تعداد واحد
  heatLoadKcal Int? // بار حرارتی محاسبه‌شده

  estimatedIrr Decimal?  @db.Decimal(18, 0) // برآورد هزینه
  finalIrr     Decimal?  @db.Decimal(18, 0)
  scheduledAt  DateTime? // زمان‌بندی اجرا
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address  Address?      @relation(fields: [addressId], references: [id], onDelete: SetNull)
  manager  User?         @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)
  items    ProjectItem[]
  tickets  Ticket[]
  deals    Deal[]
  notes    Note[]
  insights AIInsight[]

  @@index([customerId])
  @@index([type])
  @@index([status])
  @@index([managerId])
  @@index([scheduledAt])
}

model ProjectItem {
  id        String  @id @default(cuid())
  projectId String
  productId String?
  title     String // اگر محصول کاتالوگی نباشد
  quantity  Int     @default(1)
  unitIrr   Decimal @default(0) @db.Decimal(18, 0)

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([productId])
}

// ═══════════════════════════════════════════════════════════════════════════
// SALES PIPELINE  (deals)
// ═══════════════════════════════════════════════════════════════════════════

model Pipeline {
  id        String      @id @default(cuid())
  name      String // مثلاً "فروش موتورخانه"
  isDefault Boolean     @default(false)
  stages    DealStage[]
  deals     Deal[]
}

model DealStage {
  id          String  @id @default(cuid())
  pipelineId  String
  key         String // new, qualified, proposal, negotiation, ...
  name        String // نام فارسی مرحله
  order       Int // ترتیب نمایش در کانبان
  probability Int     @default(0) // درصد احتمال بستن
  isWon       Boolean @default(false)
  isLost      Boolean @default(false)

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, key])
  @@index([pipelineId, order])
}

model Deal {
  id         String     @id @default(cuid())
  code       String     @unique @default(cuid())
  title      String
  status     DealStatus @default(OPEN)
  customerId String
  pipelineId String
  stageId    String
  ownerId    String?
  projectId  String? // اگر منجر به پروژه شود

  amountIrr  Decimal   @default(0) @db.Decimal(18, 0)
  score      Int       @default(0) // امتیاز AI برای اولویت
  lostReason String?
  expectedAt DateTime? // تاریخ احتمالی بستن
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  pipeline Pipeline    @relation(fields: [pipelineId], references: [id])
  stage    DealStage   @relation(fields: [stageId], references: [id])
  owner    User?       @relation("DealOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  project  Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  items    DealItem[]
  calls    Call[]
  notes    Note[]
  insights AIInsight[]

  @@index([customerId])
  @@index([pipelineId])
  @@index([stageId])
  @@index([ownerId])
  @@index([status])
}

model DealItem {
  id        String  @id @default(cuid())
  dealId    String
  productId String?
  title     String
  quantity  Int     @default(1)
  unitIrr   Decimal @default(0) @db.Decimal(18, 0)
  discount  Decimal @default(0) @db.Decimal(18, 0)

  deal    Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([dealId])
  @@index([productId])
}

// ═══════════════════════════════════════════════════════════════════════════
// CALLS  (Issabel / Asterisk AMI)
// ═══════════════════════════════════════════════════════════════════════════

model Call {
  id         String        @id @default(cuid())
  uniqueId   String        @unique // Asterisk Uniqueid (idempotency)
  linkedId   String? // برای تماس‌های زنجیره‌ای/ترنسفر
  direction  CallDirection
  status     CallStatus    @default(RINGING)
  fromNumber String // شماره مبدا
  toNumber   String // شماره مقصد
  did        String? // شماره‌ای که مشتری گرفته
  queue      String? // صف ورودی
  channel    String? // کانال Asterisk
  agentId    String? // اپراتور پاسخگو
  customerId String? // تطبیق‌شده با مشتری (یا سرنخ ساخته‌شده)
  dealId     String?
  ticketId   String?

  waitSeconds Int? // مدت انتظار
  talkSeconds Int? // مدت مکالمه
  startedAt   DateTime  @default(now())
  answeredAt  DateTime?
  endedAt     DateTime?

  recordingPath String? // مسیر فایل ضبط روی سرور Asterisk
  recordingUrl  String? // مسیر همگام‌شده در سیستم ما
  transcript    String? // خروجی Whisper (فاز ۶)
  intent        IntentType @default(UNKNOWN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent    User?       @relation("CallAgent", fields: [agentId], references: [id], onDelete: SetNull)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  deal     Deal?       @relation(fields: [dealId], references: [id], onDelete: SetNull)
  ticket   Ticket?     @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  insights AIInsight[]

  @@index([direction])
  @@index([status])
  @@index([fromNumber])
  @@index([toNumber])
  @@index([agentId])
  @@index([customerId])
  @@index([startedAt])
}

// ═══════════════════════════════════════════════════════════════════════════
// SERVICE TICKETS
// ═══════════════════════════════════════════════════════════════════════════

model Ticket {
  id          String         @id @default(cuid())
  code        String         @unique @default(cuid())
  subject     String
  category    TicketCategory
  priority    TicketPriority @default(MEDIUM)
  status      TicketStatus   @default(OPEN)
  customerId  String
  projectId   String?
  assigneeId  String? // تکنسین/کارشناس مسئول
  description String?

  slaDueAt   DateTime? // مهلت SLA
  resolvedAt DateTime?
  closedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project  Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assignee User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments TicketComment[]
  calls    Call[]
  insights AIInsight[]

  @@index([customerId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assigneeId])
  @@index([slaDueAt])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String?
  body       String
  isInternal Boolean  @default(false) // یادداشت داخلی یا پاسخ به مشتری
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([ticketId])
}

// ═══════════════════════════════════════════════════════════════════════════
// AI INSIGHTS  (polymorphic, attached to any entity)
// ═══════════════════════════════════════════════════════════════════════════

model AIInsight {
  id         String      @id @default(cuid())
  type       InsightType
  entityType EntityType // نوع موجودیتِ مرجع
  // FKهای اختیاری برای پیوست‌کردن به موجودیت‌های پرکاربرد (پرس‌وجوی سریع‌تر از polymorphic خام)
  customerId String?
  projectId  String?
  dealId     String?
  callId     String?
  ticketId   String?

  // محتوای بینش
  summary       String? // خلاصه فارسی
  intent        IntentType?
  score         Int? // امتیاز عددی (لید/معامله)
  payload       Json? // داده ساخت‌یافته (مثلاً لیست محصولات پیشنهادی)
  confidence    Float? // اطمینان مدل 0..1
  model         String? // نام/نسخه مدل خودمیزبان
  recommendedId String? // محصول پیشنهادی (برای PRODUCT_RECOMMENDATION)

  createdAt DateTime @default(now())

  customer    Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deal        Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  call        Call?     @relation(fields: [callId], references: [id], onDelete: Cascade)
  ticket      Ticket?   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  recommended Product?  @relation("RecommendedProduct", fields: [recommendedId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([entityType])
  @@index([customerId])
  @@index([dealId])
  @@index([callId])
}

// ═══════════════════════════════════════════════════════════════════════════
// SHARED: notes, tags, activity log, notifications
// ═══════════════════════════════════════════════════════════════════════════

model Note {
  id         String   @id @default(cuid())
  body       String
  authorId   String?
  customerId String?
  projectId  String?
  dealId     String?
  createdAt  DateTime @default(now())

  author   User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([projectId])
  @@index([dealId])
}

model Tag {
  id        String        @id @default(cuid())
  name      String        @unique
  color     String?
  customers CustomerTag[]
}

model CustomerTag {
  customerId String
  tagId      String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerId, tagId])
  @@index([tagId])
}

model ActivityLog {
  id         String     @id @default(cuid())
  actorId    String?
  action     String // created, updated, status_changed, ...
  entityType EntityType
  entityId   String
  metadata   Json?
  createdAt  DateTime   @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // call:incoming, ticket:assigned, ai:insight ...
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}
