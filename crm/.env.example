# ── شفازح CRM — نمونه‌ی متغیرهای محیطی استقرار ───────────────────────────────
# کپی کنید:  cp .env.example .env   و مقادیر را پر کنید (به‌ویژه رمزها/کلیدها).

# ── پایگاه‌داده (PostgreSQL) ─────────────────────────────────────────────────
POSTGRES_USER=shofazh
POSTGRES_PASSWORD=change-this-strong-password
POSTGRES_DB=shofazh

# ── پورت ورودی Nginx ─────────────────────────────────────────────────────────
HTTP_PORT=80

# ── پشتیبان‌گیری دیتابیس (سرویس backup) ──────────────────────────────────────
BACKUP_INTERVAL=86400        # فاصله‌ی پشتیبان‌گیری (ثانیه) — ۸۶۴۰۰=روزانه، ۲۱۶۰۰=هر ۶ ساعت
BACKUP_RETENTION_DAYS=14     # چند روز پشتیبان نگه داشته شود

# ── کلیدهای JWT (هرکدام حداقل ۱۶ نویسه) ──────────────────────────────────────
# تولید مقدار امن:  openssl rand -hex 32
JWT_ACCESS_SECRET=replace-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-with-another-openssl-rand-hex-32
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# دامنه‌های مجاز CORS (هم‌مبدأ پشت Nginx ⇒ معمولاً نیازی نیست تغییر دهید).
# در تولید اگر «*» بماند، credentials cross-origin خودکار خاموش می‌شود؛
# برای cross-origin با credentials، دامنه‌ها را صریح بدهید: https://crm.example.com
CORS_ORIGINS=*

# سطح لاگ ساخت‌یافته: trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# اندازه‌ی استخر اتصال Prisma به دیتابیس به‌ازای هر اینستنس API.
# قانون سرانگشتی: DB_POOL_SIZE × تعداد اینستنس‌ها < max_connections پستگرس (پیش‌فرض ۱۰۰)
DB_POOL_SIZE=10

# مستندات Swagger در تولید به‌صورت پیش‌فرض خاموش است؛ برای فعال‌سازی روی true بگذارید
# SWAGGER_ENABLED=true

# آدرس API برای فرانت — «/api» یعنی هم‌مبدأ پشت Nginx (تغییر ندهید مگر دامنه‌ی جدا دارید)
NEXT_PUBLIC_API_URL=/api

# ── تلفن (Issabel / AMI) ─────────────────────────────────────────────────────
# تا زمان راه‌اندازی Issabel واقعی، شبیه‌ساز فعال بماند:
AMI_MOCK=true
# AMI_HOST=192.168.1.10
# AMI_PORT=5038
# AMI_USERNAME=crm
# AMI_SECRET=change-me
# Context تماس ورودی. خالی/تنظیم‌نشده ⇒ تشخیص هوشمند (اکثر نصب‌های Issabel/FreePBX).
# اگر تماس ورودی پاپ‌آپ نداد، Context واقعی را از لاگ Asterisk بردارید و اینجا بگذارید
# (چند مقدار با کاما). نمونه‌ی رایج Issabel: from-trunk-sip-sip
# AMI_INBOUND_CONTEXTS=from-trunk-sip-sip
# AMI_OUTBOUND_CONTEXT=from-internal
RECORDING_PUBLIC_BASE=/recordings

# ── هوش مصنوعی (AI) ──────────────────────────────────────────────────────────
# پیش‌فرض: شبیه‌ساز — کل سیستم بدون نیاز به هیچ مدل/کلیدی کار می‌کند.
AI_MOCK=true
STT_MOCK=true
#
# برای مدلِ واقعیِ رایگان روی مک (Ollama با شتاب Metal — رایگان، محلی):
#   ۱) روی مک:  brew install ollama && ollama serve
#   ۲)          ollama pull qwen2.5:7b
#   ۳) این مقادیر را تنظیم کنید:
# AI_MOCK=false
# AI_BASE_URL=http://host.docker.internal:11434/v1
# AI_MODEL=qwen2.5:7b
# AI_API_KEY=ollama
#
# برای تبدیل گفتار به متن واقعی (Whisper خودمیزبان) — به docs/phase-8-deploy.md مراجعه کنید:
# STT_MOCK=false
# STT_BASE_URL=http://host.docker.internal:9000
